{
  "manifest_version": 3,
  "name": "AI Leads Pro — Google Maps Scraper",
  "version": "2.0.0",
  "description": "Scrape qualified leads from Google Maps with smart filtering and CSV export",
  "permissions": [
    "activeTab",
    "tabs",
    "scripting",
    "storage",
    "downloads",
    "alarms"
  ],
  "host_permissions": [
    "https://www.google.com/*",
    "https://maps.google.com/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "AI Leads Pro"
  },
  "content_scripts": [
    {
      "matches": ["https://www.google.com/maps/*"],
      "js": ["utils.js", "scraper.js", "content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
