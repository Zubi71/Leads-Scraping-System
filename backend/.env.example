# ─── App ──────────────────────────────────────────────────────────────────────
APP_NAME="AI Business Website Acquisition System"
DEBUG=false

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=leads_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=leads_db
DATABASE_URL=postgresql://leads_user:change_me_strong_password@db:5432/leads_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=

# ─── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change_me_to_random_64_char_string_use_openssl_rand_hex_32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── AI Provider (set at least one) ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
AI_MODEL=claude-sonnet-4-6

# ─── WhatsApp Business Cloud API ──────────────────────────────────────────────
WHATSAPP_API_URL=https://graph.facebook.com/v19.0
WHATSAPP_API_TOKEN=your_permanent_token
WHATSAPP_PHONE_ID=your_phone_number_id
MY_WHATSAPP_NUMBER=+601XXXXXXXXX   # Your personal number for notifications

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=your@gmail.com
FROM_NAME="Your Business Name"

# ─── Google Places API (preferred over scraping) ──────────────────────────────
GOOGLE_PLACES_API_KEY=AIza...

# ─── Rate Limiting ────────────────────────────────────────────────────────────
SCRAPING_DELAY_SECONDS=2.0
OUTREACH_DELAY_SECONDS=10.0
MAX_MESSAGES_PER_HOUR=20
MAX_EMAILS_PER_HOUR=50

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]
